{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "wmhh-desktop",
  "version": "2.6.0",
  "identifier": "com.wooseongkyun.wmhh",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "뭐하려 했더라",
        "width": 560,
        "height": 900,
        "resizable": false,
        "maximizable": true,
        "maximized": true,
        "visible": false,
        "dragDropEnabled": false,
        "decorations": false
      },
      {
        "label": "capture",
        "url": "capture.html",
        "title": "빠른 메모",
        "width": 620,
        "height": 150,
        "visible": false,
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": false,
        "maximizable": false,
        "minimizable": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self' data:; connect-src ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": false,
    "targets": [],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
